# Public site origin. Use your production URL in Vercel.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only Vercel Blob token. Required for admin save and image upload.
BLOB_READ_WRITE_TOKEN=

# Server-only admin login password. This is the easiest no-code setup.
ADMIN_PASSWORD=

# Optional stronger setup: server-only bcrypt hash for the admin password.
# If set, this takes priority over ADMIN_PASSWORD.
# Generate with:
# node -e "const bcrypt=require('bcryptjs'); bcrypt.hash(process.argv[1], 12).then(console.log)" "your-password"
ADMIN_PASSWORD_HASH=

# Optional server-only session signing secret. If empty, the app derives one from the admin credential.
# If you set it manually, use at least 32 characters.
# Generate with:
# openssl rand -base64 48
SESSION_SECRET=
