# Public site origin. Use your production URL in Vercel.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only Vercel Blob token. Required for admin save and image upload.
BLOB_READ_WRITE_TOKEN=

# Server-only bcrypt hash for the admin password.
# Generate with:
# node -e "const bcrypt=require('bcryptjs'); bcrypt.hash(process.argv[1], 12).then(console.log)" "your-password"
ADMIN_PASSWORD_HASH=

# Server-only session signing secret. Must be at least 32 characters.
# Generate with:
# openssl rand -base64 48
SESSION_SECRET=
